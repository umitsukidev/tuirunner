{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppConfig",
  "type": "object",
  "properties": {
    "tui": {
      "default": false,
      "type": "boolean"
    },
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Task"
      }
    }
  },
  "definitions": {
    "Task": {
      "type": "object",
      "properties": {
        "run": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunCommand"
            },
            {
              "type": "null"
            }
          ]
        },
        "working_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "depends_on": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RunCommand": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    }
  }
}
