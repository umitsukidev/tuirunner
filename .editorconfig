root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.{ts,mts,js,mjs,vue,css,json,jsonc}]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.{md,mdx}]
indent_size = 4
indent_style = space
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2
indent_style = space

[*.{rs,toml}]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true
